{
  "name": "ai-agent-platform",
  "version": "0.1.0",
  "description": "AI Agent Platform with Knowledge Management, Learning Center, and Creative Workshop",
  "main": "server/dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "start": "cd server && npm start",
    "lint": "cd client && npm run lint",
    "format": "cd client && npm run format",
    "test": "npm run test:server && npm run check:superpowers && npm run test:client",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "check:superpowers": "node scripts/check-superpowers-sync.cjs"
  },
  "keywords": ["ai", "agent", "rag", "knowledge-management", "learning"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
