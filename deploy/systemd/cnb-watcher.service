[Unit]
Description=AI Agent Platform CNB production release watcher
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/default/cnb-watcher
ExecStart=/usr/local/sbin/aibak-cnb-watcher
TimeoutStartSec=30min
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6
