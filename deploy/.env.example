# 部署服务器连接配置
# 复制此文件为 .env 并填入真实值
# cp deploy/.env.example deploy/.env

# SSH 连接信息
DEPLOY_HOST=your-server-ip
DEPLOY_USER=root
DEPLOY_PASSWORD=your-secure-password
DEPLOY_TIMEOUT=15

# 远程项目路径
DEPLOY_REMOTE_PATH=/opt/ai-agent-platform

# 本地项目路径（可选，默认为脚本所在项目根目录）
# DEPLOY_LOCAL_PATH=/path/to/ai-agent-platform
