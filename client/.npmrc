# 缓解 GitHub Actions runner 上对庞大依赖树偶发的 npm 内部问题：
#  - --omit=optional（在 CI 安装命令中）跳过 esbuild 等可选原生二进制，缩减体积与内存
#  - 并发适度（maxsockets=8）：过高(15)易因并行解压内存峰值触发 OOM 崩溃
#    ("Exit handler never called")，过低(1~3)又易因单请求卡死而挂起；8 为平衡值
#  - 收紧重试退避上限（maxtimeout=120s），避免网络微抖时单次重试等待过长造成长时间挂起
maxsockets=8
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fund=false
audit=false
