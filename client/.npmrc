# 缓解 GitHub Actions runner 上对庞大依赖树偶发的 npm 内部 OOM 崩溃
# ("Exit handler never called")。
#  - CI 安装命令中 --omit=optional 跳过 esbuild 等可选原生二进制，缩减体积与内存
#  - maxsockets=4 降低并行解压内存峰值（8/15 均已验证 OOM 崩溃）
#  - 收紧重试退避上限（maxtimeout=120s），避免单请求卡死导致长时间挂起
#  - NODE_OPTIONS=--max-old-space-size=4096 给 npm 更多堆内存（由 ci.yml 注入）
maxsockets=4
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fund=false
audit=false
