# ===== 服务基础 =====
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# 对外可访问的基础地址（用于支付回调）
PUBLIC_BASE_URL=http://localhost:3000

# ===== 数据库 =====
MONGODB_URI=mongodb://localhost:27017/ai-agent-platform
REDIS_URL=redis://localhost:6379

# ===== AI 模型（缺省自动进入 Mock 模式）=====
# 设置为 true 时无需任何 Key 即可运行（返回模拟响应）
ENABLE_MOCK_MODE=true
# 默认 AI Provider（开启 Mock 且未指定时仍走 mock；指定需已配置对应 Key）
# 可选：openai | anthropic | deepseek | hunyuan | mock
DEFAULT_AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# 智谱 GLM（OpenAI 兼容，低成本中文强模型）
ZHIPU_API_KEY=
# 通义千问（阿里云 DashScope，OpenAI 兼容）；兼容别名 DASHSCOPE_API_KEY
QWEN_API_KEY=
# 豆包（火山方舟，OpenAI 兼容）；兼容别名 ARK_API_KEY
DOUBAO_API_KEY=
# 腾讯混元（大模型对话 / 文生图 / 媒体生成）—— 腾讯云 TC3 凭据
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
# 兼容旧名（不推荐使用）：HUNYUAN_API_KEY=
# 用户还可在前端「模型配置」自助接入任意 OpenAI 兼容的第三方模型（如自部署 vLLM / 其他厂商）

# ===== 认证 =====
JWT_SECRET=请替换为随机长字符串
# 默认支付渠道：mock | wechat | stripe
DEFAULT_PAY_PROVIDER=mock

# ===== 微信支付（v3，可选）=====
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY=
# 微信平台证书公钥（PEM），用于回调验签
WECHAT_PLATFORM_CERT=
WECHAT_NOTIFY_URL=

# ===== Stripe（可选）=====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== 文件上传 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===== 限流 =====
# 全局 API：窗口毫秒 / 窗口内每 IP 最大请求数
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# 认证端点（登录/注册）严格限流：防暴力破解
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
# 文生图生成专属限流：频率闸门（与「匿名每日限次」「登录配额」互补，三层防刷）
TEXT2IMG_RATE_WINDOW_MS=60000
TEXT2IMG_RATE_MAX=10

# ===== 对象存储（OSS，生产建议切到云存储）=====
# 不配置则回退本地磁盘（server/uploads/generated，由 /generated 静态提供）。
# 配置全部 COS_* 后，自动切换为腾讯云 COS，返回 CDN/公有读 URL。
# 注意：本地模式图片占用服务器磁盘与出网带宽；COS 模式有独立存储/流量计费且可加 CDN 加速。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
# 公有读或 CDN 域名（如 https://cdn.example.com），留空则返回 SDK 签名临时 URL
COS_BASE_URL=
# 生成结果在 OSS 中的生命周期（秒），到期自动清理，控制存储成本。0=不自动清理
COS_OBJECT_TTL=86400
