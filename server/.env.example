# ===== 服务基础 =====
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# 对外可访问的基础地址（用于支付回调）
PUBLIC_BASE_URL=http://localhost:3000

# ===== 数据库 =====
MONGODB_URI=mongodb://localhost:27017/ai-agent-platform
REDIS_URL=redis://localhost:6379

# ===== AI 模型（缺省自动进入 Mock 模式）=====
# 设置为 true 时无需任何 Key 即可运行（返回模拟响应）
ENABLE_MOCK_MODE=true
# 默认 AI Provider（开启 Mock 且未指定时仍走 mock；指定需已配置对应 Key）
# 可选：openai | anthropic | deepseek | hunyuan | mock
DEFAULT_AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# 智谱 GLM（OpenAI 兼容，低成本中文强模型）
ZHIPU_API_KEY=
# 通义千问（阿里云 DashScope，OpenAI 兼容）；兼容别名 DASHSCOPE_API_KEY
QWEN_API_KEY=
# 豆包（火山方舟，OpenAI 兼容）；兼容别名 ARK_API_KEY
DOUBAO_API_KEY=
# 腾讯混元（大模型对话 / 文生图 / 媒体生成）—— 腾讯云 TC3 凭据
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
# 兼容旧名（不推荐使用）：HUNYUAN_API_KEY=
# 阿里云通义万相（文生图 / 图生图）—— DashScope API Key（Bearer 鉴权）
TONGYI_API_KEY=

# 可灵 Kling（快手 AI 视频生成，Bearer Token）
KELING_API_TOKEN=
# 即梦 Jimeng（字节 AI 视频/图片生成，Bearer Token）
JIMENG_API_TOKEN=
# MoneyPrinterTurbo（外部视频工厂，整片生成 FastAPI 服务地址）
MONEY_PRINTER_TURBO_URL=

# 用户还可在前端「模型配置」自助接入任意 OpenAI 兼容的第三方模型（如自部署 vLLM / 其他厂商）

# ===== 认证 =====
JWT_SECRET=请替换为随机长字符串
# 字段级加密密钥（敏感个人信息：手机号 / 提现账号等 AES-256-GCM 落库）
# 必须 32 字节 = 64 个十六进制字符；生成：openssl rand -hex 32
# ⚠️ 缺失会导致加密字段相关功能（短信验证码注册 / 提现账号等）直接 500，务必配置（生产可配 ENCRYPTION_KEY_PREV 做密钥轮换）
ENCRYPTION_KEY=
# 默认支付渠道：mock | wechat | alipay | stripe
DEFAULT_PAY_PROVIDER=mock

# ===== 支付宝（当面付扫码，真实收款必备）=====
# 机制：默认以 # [disabled] 注释禁用，保持"保留配置"（与服务器 .env 同构）。
# 上线时：取消 # [disabled] 前缀并填入真实密钥 → docker restart ai-platform-server 即启用。
# 注意：本文件为提交到 git 的模板，仅保留字段与机制；真实密钥请勿写入此处，仅存于服务器 .env 并另行安全备份。
# 应用私钥（支付宝开放平台「开发设置→应用私钥」RSA2，PEM 或裸 base64 均可）
# [disabled] ALIPAY_APP_ID=
# [disabled] ALIPAY_PRIVATE_KEY=
# 支付宝公钥（注意不是「应用公钥」！开放平台「开发设置→支付宝公钥」RSA2），用于异步通知验签
# [disabled] ALIPAY_PUBLIC_KEY=
# 网关：正式环境 https://openapi.alipay.com/gateway.do，沙箱 https://openapi.alipaydev.com/gateway.do
# [disabled] ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# ===== 微信「网站应用」扫码登录（OAuth2，可选）=====
# 来源：微信开放平台 → 网站应用（不是公众号/小程序！）→ AppID / AppSecret
# 与 WECHAT_MCH_ID（微信支付商户）是两套完全不同的凭据，请勿混淆。
# 两个都填 → 前端"微信扫码登录"自动启用；任一为空 → 自动降级为演示模式（mock）。
WECHAT_OPEN_APPID=
WECHAT_OPEN_SECRET=
# 回调地址（可选，默认 PUBLIC_BASE_URL + /api/auth/wechat/callback，需与开放平台后台配置一致）
WECHAT_LOGIN_REDIRECT=

# ===== 抖音「网站应用」扫码登录（OAuth2，可选）=====
# 来源：抖音开放平台 → 网站应用 → Client Key / Client Secret
# 注册指引见 docs/LOCAL-SERVER-GUIDE.md 或 plan 文件 Part B0
# 未配置时自动进入 Mock 模式，前端可正常开发 UI
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
# 回调地址（需与抖音开放平台后台配置一致）
DOUYIN_REDIRECT_URI=http://localhost:8080/api/auth/douyin/callback

# ===== 短信服务商（手机号验证码登录，可选）=====
# 提供商：aliyun | tencent；真实发送需填对应密钥 + 签名 + 模板；缺省走开发态 Mock（回显验证码）
SMS_PROVIDER=
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=

# ===== 微信支付（v3，可选）=====
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY=
# 微信平台证书公钥（PEM），用于回调验签
WECHAT_PLATFORM_CERT=
WECHAT_NOTIFY_URL=

# ===== Stripe（可选，默认 # [disabled] 保留配置）=====
# 上线时：取消 # [disabled] 前缀并填入真实密钥 → docker restart ai-platform-server 即启用。
# [disabled] STRIPE_SECRET_KEY=
# [disabled] STRIPE_WEBHOOK_SECRET=
# [disabled] STRIPE_PUBLISHABLE_KEY=
# [disabled] STRIPE_NOTIFY_URL=https://aibak.site/api/billing/webhook/stripe

# ===== 文件上传 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===== 限流 =====
# 全局 API：窗口毫秒 / 窗口内每 IP 最大请求数
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# 认证端点（登录/注册）严格限流：防暴力破解
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
# 文生图生成专属限流：频率闸门（与「匿名每日限次」「登录配额」互补，三层防刷）
TEXT2IMG_RATE_WINDOW_MS=60000
TEXT2IMG_RATE_MAX=10

# ===== 对象存储（OSS，生产建议切到云存储）=====
# 不配置则回退本地磁盘（server/uploads/generated，由 /generated 静态提供）。
# 配置全部 COS_* 后，自动切换为腾讯云 COS，返回 CDN/公有读 URL。
# 注意：本地模式图片占用服务器磁盘与出网带宽；COS 模式有独立存储/流量计费且可加 CDN 加速。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
# 公有读或 CDN 域名（如 https://cdn.example.com），留空则返回 SDK 签名临时 URL
COS_BASE_URL=
# 生成结果在 OSS 中的生命周期（秒），到期自动清理，控制存储成本。0=不自动清理
COS_OBJECT_TTL=86400
