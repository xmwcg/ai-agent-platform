# ===== AIbak 生产环境变量模板 =====
# 仅用于说明变量名；真实值必须由 CNB Secret / 服务器 Secret 文件注入，禁止提交。

# ===== 服务基础 =====
PORT=3000
NODE_ENV=production
CLIENT_URL=https://aibak.site
PUBLIC_BASE_URL=https://aibak.site
APP_COMMIT_SHA=
SERVER_IMAGE_DIGEST=
CLIENT_IMAGE_DIGEST=

# ===== 托管基础设施（生产不得使用本机 Compose MongoDB/Redis） =====
MONGODB_URI=
REDIS_URL=

# ===== 生产 Mock 强制关闭 =====
ENABLE_MOCK_MODE=false
MOCK_MODE=false
DEFAULT_PAY_PROVIDER=wechat

# ===== 真实 AI（至少配置一个厂商） =====
DEFAULT_AI_PROVIDER=deepseek
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
QWEN_API_KEY=

# ===== 认证与字段加密 =====
# JWT_SECRET 至少 48 个随机字符；建议使用 openssl rand -hex 32。
JWT_SECRET=
# 32 字节十六进制密钥（64 hex），使用 openssl rand -hex 32 生成。
ENCRYPTION_KEY=

# ===== 独立远程 Sandbox =====
SANDBOX_MODE=remote
SANDBOX_REMOTE_URL=https://sandbox.internal.example.com
SANDBOX_REMOTE_TOKEN=
SANDBOX_LOCAL_ENABLED=false

# ===== 微信网站扫码登录（未接入时前端隐藏，不提供演示登录） =====
WECHAT_OPEN_APPID=
WECHAT_OPEN_SECRET=

# ===== 微信小程序登录（引流小程序，独立凭据；未配置时接口返回未配置提示） =====
WECHAT_MINI_APPID=wx0fd7eea093acd207
WECHAT_MINI_SECRET=615110fabeec24e53484542183ef04b1

# ===== 私有化授权（金网通 store 签发联动；未配 TOKEN 时不实际签发） =====
JINWANGTONG_STORE_URL=http://127.0.0.1:3100
JINWANGTONG_ADMIN_TOKEN=

# ===== 通知（未接入真实渠道时必须显式 disabled） =====
NOTIFY_CHANNEL=disabled
WECHAT_NOTIFY_TEMPLATE_ID=

# ===== 短信（真实 SDK 未接入，生产禁止启用） =====
SMS_PROVIDER=
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=

# ===== 微信支付 API v3（首发唯一生产支付渠道） =====
WECHAT_MCH_ID=
WECHAT_APP_ID=
# 必须恰好 32 个字符。
WECHAT_API_V3_KEY=
# 商户 API 证书序列号。
WECHAT_CERT_SERIAL=
# 商户 RSA 私钥，支持完整 PEM 或使用 \n 转义的单行 PEM。
WECHAT_PRIVATE_KEY=
# 微信支付平台 X.509 证书，生产回调必须据此验签。
WECHAT_PLATFORM_CERT=
WECHAT_NOTIFY_URL=https://aibak.site/api/billing/webhook/wechat

# ===== 文件上传 =====
UPLOAD_DIR=/usr/src/app/uploads
MAX_FILE_SIZE=10485760

# ===== 限流 =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
