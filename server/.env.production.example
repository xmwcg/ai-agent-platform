# ===== 方案② 轻量服务器 · 生产环境变量模板 =====
# 用法：复制为 server/.env 并填入真实值。
# 该文件仅含占位符，可安全提交；真实 .env 已被 .gitignore 忽略。

# ===== 服务基础 =====
PORT=3000
NODE_ENV=production
# 前端访问地址（用于跨域白名单，阶段2改为 https://你的域名）
CLIENT_URL=http://服务器IP
# 对外可访问的基础地址（用于支付回调，阶段2改为 https://你的域名）
PUBLIC_BASE_URL=http://服务器IP

# ===== 数据库（docker-compose 内网地址，勿改）=====
MONGODB_URI=mongodb://mongodb:27017/ai-agent-platform
REDIS_URL=redis://redis:6379

# ===== AI 模型（国内主流，成本最低；缺省自动回退 Mock）=====
ENABLE_MOCK_MODE=false
# 默认对话走国产模型：deepseek / hunyuan / qwen
DEFAULT_AI_PROVIDER=deepseek
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=            # 必填推荐：国产最便宜，对话/代码首选
HUNYUAN_SECRET_ID=           # 可选：混元对话/文生图/媒体生成（TC3 真实验签）
HUNYUAN_SECRET_KEY=
QWEN_API_KEY=                # 可选：通义千问

# ===== 认证 =====
# 生产环境弱值会被启动拦截 exit(1)。请用强随机： openssl rand -hex 32
JWT_SECRET=请替换为>=32位随机字符串
# 默认支付渠道：wechat | alipay | stripe | mock
DEFAULT_PAY_PROVIDER=wechat

# ===== 字段加密密钥 =====
# 用于加密落库的第三方 ModelConfig.apiKey（AES-256-GCM）
# 务必替换为 32 字节 hex（64 字符），生成命令： openssl rand -hex 32
# 仅存服务器、勿提交、勿进镜像；泄露等同于 key 泄露，请定期轮换
ENCRYPTION_KEY=请替换为 openssl rand -hex 32 生成的64位十六进制字符串

# ===== 微信支付 v3（公司商户号，你已具备）=====
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
# 私钥：可粘贴完整 PEM（保留换行），或用 \n 转义；生产必备，防伪造订单
WECHAT_PRIVATE_KEY=
# 微信平台证书公钥（PEM），用于回调验签；生产必填，否则跳过回调验签
WECHAT_PLATFORM_CERT=
# 回调地址：必须为公网 HTTPS，阶段2改为 https://你的域名/api/billing/webhook/wechat
WECHAT_NOTIFY_URL=http://服务器IP/api/billing/webhook/wechat

# ===== Stripe（可选，出海用）=====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== 支付宝（当面付扫码，真实收款必备）=====
# 应用私钥（支付宝开放平台「开发设置→应用私钥」RSA2，PEM 或裸 base64 均可，脚本自动补全 PEM 头尾）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（注意不是「应用公钥」！开放平台「开发设置→支付宝公钥」RSA2），用于异步通知验签防伪造
ALIPAY_PUBLIC_KEY=
# 网关地址：正式环境默认 https://openapi.alipay.com/gateway.do，沙箱用 https://openapi.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 支付宝异步通知地址（PUBLIC_BASE_URL 自动拼接，无需手填；此处仅作说明）
# 实际回调： http://服务器IP/api/billing/webhook/alipay


# ===== 文件上传 =====
UPLOAD_DIR=/usr/src/app/uploads
MAX_FILE_SIZE=10485760

# ===== 限流 =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
