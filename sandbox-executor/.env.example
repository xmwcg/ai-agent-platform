# 沙箱执行器鉴权令牌（与主站 SANDBOX_REMOTE_TOKEN 一致）
SANDBOX_AUTH_TOKEN=change-me-to-a-random-64-char-string

# 执行器监听端口
SANDBOX_PORT=4090

# 执行限制
MAX_TIMEOUT_MS=10000
MAX_MEMORY_MB=256
MAX_CPU_SHARES=0.5
MAX_PIDS=64
MAX_OUTPUT_BYTES=65536

# Docker 镜像（可按需自定义）
DOCKER_IMAGE_PYTHON=python:3.12-slim
DOCKER_IMAGE_NODE=node:20-slim
DOCKER_IMAGE_TS=node:20-slim
DOCKER_IMAGE_BASH=alpine:3.19
